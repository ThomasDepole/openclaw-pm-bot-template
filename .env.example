# Copy this file to .env and fill in your credentials.
# .env is git-ignored — never commit real credentials.

# ── Task Management ─────────────────────────────────────────────────
# Uncomment and fill in the section for your tool.

# Trello
# TRELLO_API_KEY=
# TRELLO_TOKEN=

# Jira
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# JIRA_BASE_URL=https://yourcompany.atlassian.net

# Azure DevOps
# ADO_ORG=https://dev.azure.com/yourorg
# ADO_PROJECT=YourProjectName
# ADO_PAT=

# Linear
# LINEAR_API_KEY=

# GitHub Issues
# GITHUB_TOKEN=
# GITHUB_REPO=org/repo-name

# Asana
# ASANA_PAT=

# ── Other Integrations ───────────────────────────────────────────────

# Slack (webhook for notifications, if configured)
# SLACK_WEBHOOK_URL=

# OpenAI (if any scripts use it directly)
# OPENAI_API_KEY=
